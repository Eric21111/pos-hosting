# ===========================================
# POS Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=production

# Database (MongoDB Atlas)
# Get your connection string from MongoDB Atlas Dashboard
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pos-system?retryWrites=true&w=majority

# Cloud-Only Mode (set to true for hosted backends like Render)
# This disables local database fallback and connection monitoring
CLOUD_ONLY=true

# Disable sync service on cloud (no local DB to sync with)
ENABLE_SYNC=false

# Frontend URL (for CORS - your Vercel deployment URL)
FRONTEND_URL=https://your-app.vercel.app

# Email Configuration
# Option 1: Brevo (recommended for cloud hosting like Render)
# Get your API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-your-api-key-here
EMAIL_FROM=your-verified-email@domain.com

# Option 2: Gmail (for local development only - blocked on Render free tier)
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-specific-password

# Store Information
STORE_NAME=CreateYourStyle
STORE_ADDRESS=Pasonanca, Zamboanga City

# Receipt Configuration
RECEIPT_CHAR_WIDTH=32
PRINTER_CURRENCY_SYMBOL=P

# Encryption (generate a random 64-character hex string)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=your-64-character-hex-secret-here

# PayMongo/GCash Configuration (optional)
# PAYMONGO_SECRET_KEY=sk_test_xxx
# PAYMONGO_WEBHOOK_SECRET=whsk_xxx
# WEBHOOK_BASE_URL=https://your-backend.onrender.com
